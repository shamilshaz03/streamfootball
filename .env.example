# ── Telegram ──────────────────────────────────────────────────────────────
# Get from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFabcdef1234567890abcdef12345678

# Optional: public Telegram channel/group ID where match broadcasts are posted.
# The bot will post live/halftime/finished status updates here, deleting the
# previous one so the channel stays clean. Leave blank to disable.
TELEGRAM_BROADCAST_CHAT_ID=

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=football_db
POSTGRES_USER=football
POSTGRES_PASSWORD=changeme_strong_password

# Full URL used by the backend (overridden by docker-compose for the
# container service name; set manually for local dev)
DATABASE_URL=postgresql+psycopg2://football:changeme_strong_password@localhost:5432/football_db

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate a secure random value: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_64_hex_chars_generated_randomly
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ── First Super Admin (created on first boot if no admins exist) ──────────
FIRST_SUPER_ADMIN_USERNAME=admin
FIRST_SUPER_ADMIN_PASSWORD=ChangeMe123!
FIRST_SUPER_ADMIN_EMAIL=admin@example.com

# ── CORS (comma-separated list of allowed origins) ───────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Uploads ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=10/minute

# ── Bot API base URL (used inside Docker; leave as default for Docker Compose)
API_BASE_URL=http://backend:8000/api/v1
